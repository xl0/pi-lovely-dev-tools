{
	"name": "@xl0/pi-lovely-dev-tools",
	"version": "0.1.0",
	"keywords": [
		"pi-package",
		"dev tools",
		"tools"
	],
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/xl0/pi-lovely-dev-tools#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xl0/pi-lovely-dev-tools.git"
	},
	"files": [
		"extensions/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"check": "bun run typecheck && bun run biome:check",
		"release": "bun publish --access public",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@earendil-works/pi-coding-agent": "file:../pi-mono/packages/coding-agent",
		"@earendil-works/pi-tui": "file:../pi-mono/packages/tui",
		"@typescript/native-preview": "^7.0.0-dev.20260502.1",
		"bun-types": "^1.3.13",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"pi": {
		"extensions": [
			"./extensions"
		]
	}
}
